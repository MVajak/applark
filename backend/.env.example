DATABASE_URL=postgresql+asyncpg://applark:dev@localhost:5434/applark
REDIS_URL=redis://localhost:6379/0

ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...

ENVIRONMENT=development
LOG_LEVEL=INFO
DEBUG=true
ALLOWED_ORIGINS=["http://localhost:5173"]

# Auth — generate strong unique values for non-dev (e.g. `openssl rand -hex 32`)
JWT_SECRET=dev-insecure-jwt-secret-change-me
OTP_PEPPER=dev-insecure-otp-pepper-change-me
JWT_ACCESS_TTL_MINUTES=15
JWT_REFRESH_TTL_DAYS=30
OTP_TTL_MINUTES=10
OTP_MAX_ATTEMPTS=5
OTP_REQUEST_LIMIT_PER_HOUR=5

EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536

LLM_MODEL_FAST=anthropic:claude-haiku-4-5
LLM_MODEL_SMART=anthropic:claude-sonnet-4-6
