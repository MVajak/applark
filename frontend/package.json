{
  "name": "applark-frontend",
  "private": true,
  "version": "0.0.0",
  "packageManager": "pnpm@10.19.0",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=10.0.0"
  },
  "scripts": {
    "dev": "pnpm --filter @applark/web dev",
    "build": "pnpm --filter @applark/web build",
    "preview": "pnpm --filter @applark/web preview",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "gen:api": "pnpm --filter @applark/web gen:api",
    "typecheck": "pnpm --recursive typecheck"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.11",
    "typescript": "~6.0.2"
  }
}
